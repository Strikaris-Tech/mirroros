{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mirroros.dev/schemas/reflection_context.schema.json",
  "title": "Reflection Context",
  "description": "Schema for reflection trigger context in MRS",
  "type": "object",
  "required": [
    "reflection_id",
    "agent",
    "triggered_at",
    "trigger_reason",
    "pattern"
  ],
  "properties": {
    "reflection_id": {
      "type": "string",
      "pattern": "^reflection_[0-9]{8}_[0-9]{3}$",
      "description": "Unique reflection identifier (format: reflection_YYYYMMDD_NNN)"
    },
    "agent": {
      "type": "string",
      "minLength": 1,
      "description": "Agent being asked to reflect"
    },
    "triggered_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of reflection trigger"
    },
    "trigger_reason": {
      "type": "string",
      "enum": [
        "pattern_detected",
        "scheduled_review",
        "manual_request",
        "consensus_needed",
        "performance_degradation",
        "contradiction_detected"
      ],
      "description": "Reason for triggering reflection"
    },
    "pattern": {
      "type": "object",
      "required": ["type", "occurrences", "confidence"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "repeated_failure",
            "performance_degradation",
            "systematic_error",
            "missed_pattern",
            "suboptimal_decision"
          ],
          "description": "Type of pattern detected"
        },
        "occurrences": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^outcome_[0-9]{8}_[0-9]{3}$"
          },
          "minItems": 1,
          "description": "Outcome IDs that form this pattern"
        },
        "common_elements": {
          "type": "object",
          "description": "Shared characteristics across pattern occurrences",
          "properties": {
            "action_type": {"type": "string"},
            "failure_reason": {"type": "string"},
            "context_similarity": {"type": "number"}
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Confidence that this is a meaningful pattern (0.0-1.0)"
        },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"],
          "description": "Severity of the pattern"
        }
      },
      "description": "Detected pattern requiring reflection"
    },
    "relevant_outcomes": {
      "type": "array",
      "items": {
        "$ref": "outcome.schema.json"
      },
      "description": "Full outcome details for pattern instances"
    },
    "historical_context": {
      "type": "object",
      "properties": {
        "similar_past_patterns": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^reflection_[0-9]{8}_[0-9]{3}$"
          },
          "description": "Previous reflections on similar patterns"
        },
        "previous_resolutions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "proposal_id": {"type": "string"},
              "outcome": {"type": "string"},
              "effectiveness": {"type": "number"}
            }
          },
          "description": "How similar patterns were resolved before"
        },
        "baseline_performance": {
          "type": "object",
          "description": "Performance metrics before this pattern emerged"
        }
      },
      "description": "Historical context for informed reflection"
    },
    "suggested_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "action_type": {
            "type": "string",
            "enum": [
              "belief_revision",
              "parameter_adjustment",
              "add_constraint",
              "seek_consensus",
              "request_human_review"
            ]
          },
          "description": {"type": "string"},
          "priority": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          }
        }
      },
      "description": "Suggested actions based on pattern analysis"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "in_progress",
        "proposal_submitted",
        "resolved",
        "dismissed"
      ],
      "description": "Current status of reflection"
    },
    "resolution": {
      "type": ["object", "null"],
      "properties": {
        "resolved_at": {
          "type": "string",
          "format": "date-time"
        },
        "resolution_type": {
          "type": "string",
          "enum": [
            "belief_revised",
            "parameter_adjusted",
            "no_action_needed",
            "escalated_to_human"
          ]
        },
        "proposal_ids": {
          "type": "array",
          "items": {"type": "string"}
        },
        "outcome_summary": {
          "type": "string"
        }
      },
      "description": "Resolution details (when status=resolved)"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "priority": {
          "type": "string",
          "enum": ["low", "medium", "high", "urgent"]
        },
        "deadline": {
          "type": "string",
          "format": "date-time",
          "description": "Time by which reflection should be completed"
        },
        "tags": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    }
  }
}
