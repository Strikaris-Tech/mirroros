{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mirroros.dev/schemas/outcome.schema.json",
  "title": "Action Outcome",
  "description": "Schema for recording action outcomes in MRS outcome tracking",
  "type": "object",
  "required": [
    "outcome_id",
    "action_id",
    "timestamp",
    "agent",
    "action_type",
    "expected",
    "actual",
    "success"
  ],
  "properties": {
    "outcome_id": {
      "type": "string",
      "pattern": "^outcome_[0-9]{8}_[0-9]{3}$",
      "description": "Unique outcome identifier (format: outcome_YYYYMMDD_NNN)"
    },
    "action_id": {
      "type": "string",
      "pattern": "^action_[0-9]{8}_[0-9]{3}$",
      "description": "ID of the action that produced this outcome"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when outcome was recorded"
    },
    "agent": {
      "type": "string",
      "minLength": 1,
      "description": "Agent that performed the action"
    },
    "action_type": {
      "type": "string",
      "description": "Type of action (e.g., code_review, memory_access, inference)"
    },
    "expected": {
      "type": "string",
      "description": "Expected outcome description"
    },
    "actual": {
      "type": "string",
      "description": "Actual outcome that occurred"
    },
    "success": {
      "type": "boolean",
      "description": "Whether the outcome matched expectations"
    },
    "metadata": {
      "type": "object",
      "description": "Additional context about the outcome",
      "properties": {
        "reason": {
          "type": "string",
          "description": "Reason for failure (if success=false)"
        },
        "error_message": {
          "type": "string",
          "description": "Technical error message"
        },
        "metrics": {
          "type": "object",
          "description": "Performance or quality metrics"
        },
        "context": {
          "type": "object",
          "description": "Environmental context at time of outcome"
        }
      }
    },
    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"],
      "description": "Severity of failure (if success=false)"
    },
    "resolution_status": {
      "type": "string",
      "enum": ["unresolved", "under_review", "resolved", "wont_fix"],
      "description": "Current resolution status for failures"
    },
    "related_outcomes": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^outcome_[0-9]{8}_[0-9]{3}$"
      },
      "description": "Related outcome IDs (similar failures, follow-up attempts)"
    }
  }
}
