{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mirroros.dev/schemas/belief.schema.json",
  "title": "Belief Ledger Entry",
  "description": "Schema for versioned agent beliefs in MRS belief ledger",
  "type": "object",
  "required": [
    "belief_id",
    "version",
    "agent",
    "belief_type",
    "content",
    "adopted",
    "status"
  ],
  "properties": {
    "belief_id": {
      "type": "string",
      "pattern": "^belief_[a-z]+_[0-9]{3}_v[0-9]+$",
      "description": "Unique belief identifier (format: belief_{agent}_{number}_v{version})"
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Version number of this belief (increments on revision)"
    },
    "agent": {
      "type": "string",
      "minLength": 1,
      "description": "Agent that holds this belief"
    },
    "belief_type": {
      "type": "string",
      "enum": [
        "rule",
        "fact",
        "constraint",
        "heuristic",
        "preference"
      ],
      "description": "Category of belief"
    },
    "content": {
      "type": "string",
      "minLength": 1,
      "description": "Belief content in Prolog syntax"
    },
    "adopted": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when belief was adopted"
    },
    "supersedes": {
      "type": ["string", "null"],
      "pattern": "^belief_[a-z]+_[0-9]{3}_v[0-9]+$",
      "description": "ID of previous belief version (null for v1)"
    },
    "superseded_by": {
      "type": ["string", "null"],
      "pattern": "^belief_[a-z]+_[0-9]{3}_v[0-9]+$",
      "description": "ID of newer belief version (null for active)"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "deprecated",
        "archived",
        "invalidated"
      ],
      "description": "Current status of this belief version"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^outcome_[0-9]{8}_[0-9]{3}$"
      },
      "description": "Outcome IDs that support this belief"
    },
    "verification_result": {
      "type": "string",
      "enum": ["VALID", "INVALID", "UNVERIFIED"],
      "description": "Result of formal verification"
    },
    "z3_proof_hash": {
      "type": ["string", "null"],
      "description": "Hash of Z3 proof for this belief"
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Confidence score based on evidence strength"
    },
    "provenance": {
      "type": "object",
      "properties": {
        "origin": {
          "type": "string",
          "enum": ["initial", "learned", "human_provided", "consensus"],
          "description": "How this belief originated"
        },
        "proposal_id": {
          "type": ["string", "null"],
          "pattern": "^edit_[0-9]{8}_[0-9]{3}$",
          "description": "ID of proposal that created this belief (if learned)"
        },
        "reflection_id": {
          "type": ["string", "null"],
          "pattern": "^reflection_[0-9]{8}_[0-9]{3}$",
          "description": "ID of reflection that triggered this belief"
        }
      },
      "description": "Tracking information about belief origin"
    },
    "performance_metrics": {
      "type": "object",
      "properties": {
        "success_rate": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Success rate when this belief is applied"
        },
        "usage_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of times this belief has been used"
        },
        "last_used": {
          "type": "string",
          "format": "date-time",
          "description": "Last time this belief was applied"
        }
      },
      "description": "Performance tracking for this belief"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "tags": {
          "type": "array",
          "items": {"type": "string"}
        },
        "notes": {
          "type": "string"
        },
        "related_beliefs": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "description": "Additional metadata"
    }
  }
}
